<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/industrial_background"
    android:paddingHorizontal="24dp">

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/editOperador"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="66dp"
        android:backgroundTint="@color/industrial_text"
        android:hint="@string/operador"
        android:inputType="textPersonName"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:singleLine="true"
        android:textColor="@color/industrial_text"
        android:textColorHint="@color/industrial_hint"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/editLinha"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/industrial_text"
        android:hint="@string/linha_producao"
        android:inputType="text"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:singleLine="true"
        android:textColor="@color/industrial_text"
        android:textColorHint="@color/industrial_hint"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/editOperador" />

    <TextView
        android:id="@+id/textPecas"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:text="@string/pecas_zero"
        android:textColor="@color/industrial_text"
        android:textSize="26sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/editLinha" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonIniciar"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="32dp"
        android:text="@string/iniciar_producao"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/industrial_primary"
        app:cornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textPecas" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonRegistrar"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="14dp"
        android:enabled="false"
        android:text="@string/registrar_peca"
        android:textAllCaps="false"
        android:textColor="@color/industrial_hint"
        app:backgroundTint="@color/industrial_disabled"
        app:cornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonIniciar" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonFinalizar"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="14dp"
        android:text="@string/finalizar_producao"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/industrial_primary"
        app:cornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonRegistrar" />

</androidx.constraintlayout.widget.ConstraintLayout>
